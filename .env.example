# Backend API Configuration
VITE_BACKEND_URL=http://localhost:3000

# Default city for initial load
VITE_DEFAULT_CITY=elprat

# Supported cities (comma-separated)
VITE_SUPPORTED_CITIES=elprat,testcity

# JWT Token (for development/testing)
VITE_JWT_TOKEN=

# PDF polling configuration
VITE_PDF_POLL_INTERVAL=2000
VITE_PDF_POLL_MAX_RETRIES=30

# App configuration
VITE_APP_TITLE=ComplAI
VITE_APP_VERSION=1.0.0

# Feature flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_LANGUAGE_SELECTOR=true
